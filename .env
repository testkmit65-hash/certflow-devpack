# DEV PACK (SANITIZED) — safe to share with contractors
# No real domains, no brand assets, no real credentials.

APP_ENV=dev_sanitized
APP_SECRET=devpack-change-me

# Local URLs
BASE_URL=http://localhost:8000
ALLOW_LOCAL_EMAIL_LINKS=1
CERT_GENERATOR_URL=http://127.0.0.1:8000/cert_engine.php?name=
EMAIL_LIVE_BASE_URL=http://localhost:8000

# Demo book/challenge
BOOK_ID=demo-book
CHALLENGE_NAME="Demo Challenge"
SECRET_KEY_CODE=AAAAAAAAAAAAAAA

PRIVACY_LAST_UPDATED=2026-01-01
COPYRIGHT_YEAR=2026
BONUS_FILENAME=bonus.pdf

# Disable ALL outbound email in this dev pack
EMAIL_DISABLE=1
SMTP_USE=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME="Demo"
EMAIL_FROM=demo@example.test
EMAIL_SUBJECT="Demo confirmation"
EMAIL_SUBJECT_EN="Demo confirmation ✅"
EMAIL_SUBJECT_DE="Demo Bestätigung ✅"
SUPPORT_EMAIL=support@example.test

# Unsubscribe (demo)
UNSUBSCRIBE_URL=http://localhost:8000/unsubscribe.php
UNSUBSCRIBE_SECRET=devpack-unsub-secret-change-me

# Email logo path
BRAND_LOGO_EMAIL_URL=/assets/img/logo-email.png

# Marker flag for conditional behavior in code
DEVPACK=1
