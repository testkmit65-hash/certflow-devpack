# Example environment variables (SAFE TEMPLATE)
# Copy this file to `.env` and fill in values.
# NOTE: In the dev pack, EMAIL_DISABLE=1 prevents any outbound email.

APP_ENV=local
APP_SECRET=REPLACE_ME_WITH_STRONG_RANDOM

# Cooldown between requests (minutes)
COOLDOWN_MINUTES=30

# Base URL (local dev)
BASE_URL=http://localhost:8000

# Email safety guard:
ALLOW_LOCAL_EMAIL_LINKS=1

# Used only when localhost links are blocked and BASE_URL is localhost.
EMAIL_LIVE_BASE_URL=http://localhost:8000

# Certificate generator endpoint
CERT_GENERATOR_URL=http://127.0.0.1:8001/cert_engine.php?name=

# Book / Challenge quick settings
BOOK_ID=demo-book
CHALLENGE_NAME="Demo Challenge"
SECRET_KEY_CODE=AAAAAAAAAAAAAAA

PRIVACY_LAST_UPDATED=2026-01-01
COPYRIGHT_YEAR=2026
BONUS_FILENAME=bonus.pdf

# Email settings
# Set EMAIL_DISABLE=1 to prevent any outbound email (recommended for contractors)
EMAIL_DISABLE=1
SMTP_USE=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME="Demo"
EMAIL_FROM=demo@example.test
EMAIL_SUBJECT="Demo confirmation"
EMAIL_SUBJECT_EN="Demo confirmation ✅"
EMAIL_SUBJECT_DE="Demo Bestätigung ✅"
SUPPORT_EMAIL=support@example.test
BRAND_LOGO_EMAIL_URL=/assets/img/logo-email.png

# Global unsubscribe (demo)
UNSUBSCRIBE_URL=http://localhost:8000/unsubscribe.php
UNSUBSCRIBE_SECRET=REPLACE_ME_WITH_STRONG_RANDOM
SUPPRESSION_FILE=storage/suppression/marketing_suppression.jsonl

# Optional certificate rendering
# PDF_ENGINE=dompdf              # dompdf | imagick | placeholder
# CERT_OUTPUT_FORMAT=pdf         # pdf | png
